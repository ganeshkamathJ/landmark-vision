# ══════════════════════════════════════════════════════════════
# Landmark Vision — Environment Variables
# Copy this file to .env and fill in your keys.
# ══════════════════════════════════════════════════════════════

# ── FREE: HuggingFace token ──────────────────────────────────
# Get yours FREE at: https://huggingface.co/settings/tokens
# → Sign up → Settings → Access Tokens → New token (read access is enough)
HUGGINGFACE_TOKEN=

# ── Google Cloud Vision (1000 free requests/month) ───────────
# → https://console.cloud.google.com → Vision API → Credentials
GOOGLE_VISION_API_KEY=

# ── OpenAI GPT-4o Vision (~$0.01/image) ─────────────────────
# → https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Flask settings ────────────────────────────────────────────
FLASK_DEBUG=True
SECRET_KEY=landmark-vision-secret-2024
